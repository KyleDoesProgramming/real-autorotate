<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/rotation_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fitsSystemWindows="true"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="@dimen/space_sm">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/rotation_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIcon="@drawable/ms_arrow_back_24"
            app:navigationIconTint="?attr/colorOnSurface"
            app:popupTheme="@style/AppTheme.PopupOverlay"
            app:subtitle="@string/rotation_config_subtitle"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/rotation_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingStart="@dimen/space_md"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/space_md"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ms_tune_24"
                            app:tint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_xs"
                            android:text="@string/rotation_rule_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/rotation_mode_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rotation_follow_default"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_rule_follow_default" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rotation_lock_rotation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_lock_rotation" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rotation_allow_rotation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_allow_rotation" />

                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rotation_specific_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/rotation_specific_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <RadioGroup
                        android:id="@+id/rotation_specific_lock_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/lock_rotation_0"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_portrait_label" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/lock_rotation_90"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_landscape_label" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/lock_rotation_180"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_reverse_portrait_label" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/lock_rotation_270"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_reverse_landscape_label" />

                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/rotation_specific_allow_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="vertical">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/allow_rotation_0"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_portrait_label" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/allow_rotation_90"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_landscape_label" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/allow_rotation_180"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_reverse_portrait_label" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/allow_rotation_270"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rotation_reverse_landscape_label" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rotation_save_button"
        style="@style/Widget.App.Button.Tonal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_gravity="bottom"
        android:text="@string/rotation_config_save"
        app:icon="@drawable/ms_check_24"
        app:iconGravity="textStart" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>